<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>de.strompreis</string>

    <key>ProgramArguments</key>
    <array>
        <!-- Pfad zum Python-Interpreter der virtuellen Umgebung anpassen: -->
        <string>/PFAD/ZU/.venv/bin/python3</string>
        <!-- Pfad zur strompreis.py anpassen: -->
        <string>/PFAD/ZU/mac-menubar-strompreis/strompreis.py</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/strompreis.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/strompreis_error.log</string>
</dict>
</plist>
